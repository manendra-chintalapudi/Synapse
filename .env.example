# ============================================================================
# Synapse BACKEND environment (Railway → Variables). Copy to synapse/.env for
# local dev. Never commit the real .env (it is git-ignored).
# ============================================================================

# --- Neo4j (local bolt for dev, or Neo4j AuraDB for production) ---
# AuraDB gives you a neo4j+s:// URI, a username, and a generated password (in the
# downloaded creds file). NOTE: AuraDB's file names the user NEO4J_USERNAME — the app
# accepts either NEO4J_USER or NEO4J_USERNAME. The username is often the instance id,
# NOT literally "neo4j" — use exactly what the creds file shows. NEO4J_DATABASE is not
# needed (the app uses the default database).
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=synapse123

# --- OpenRouter (router tier-3 + synthesizer LLM calls) ---
# Get a key at https://openrouter.ai/keys — REQUIRED for answers to generate.
OPENROUTER_API_KEY=

# --- CORS: which frontend origin(s) may call this API ---
# "*" allows any origin (fine to start). Tighten to your Vercel domain, e.g.
# ALLOWED_ORIGINS=https://synapse.vercel.app,https://www.synapse.vercel.app
ALLOWED_ORIGINS=*

# --- Performance / Railway startup tuning ---
WARM_UP_ON_STARTUP=false
SYNTHESIZER_TIMEOUT_S=45
SYNTHESIZER_MAX_TOKENS=1200
SYNTHESIZER_REASONING_EFFORT=medium
ROUTER_TIMEOUT_S=20
ROUTER_MAX_TOKENS=500
QUERY_CACHE_TTL_S=300
QUERY_CACHE_MAX_ENTRIES=128

# --- Data paths (optional) ---
# Defaults point at the pre-built files bundled in the repo/image. Override only
# if you mount a Railway volume and copy the data there instead.
# DUCKDB_DIR=/data/duckdb
# CHROMA_DIR=/data/chroma

# Note: PORT is provided automatically by Railway — do NOT set it here.
