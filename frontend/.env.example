# ============================================================================
# Synapse FRONTEND config (Vercel).
#
# This is a STATIC site (no Vite/Next build), so there is no VITE_/NEXT_PUBLIC_
# build-time env injection. The single required setting is the backend URL, and
# it is applied in frontend/config.js:
#
#     window.SYNAPSE_API_URL = "https://<your-railway-backend>.up.railway.app";
#
# The frontend calls  ${SYNAPSE_API_URL}/api/ask . Leave it "" to use the same
# origin that served the page (local dev, where FastAPI serves the frontend too).
#
# On Vercel: deploy the synapse/frontend/ folder as the project root, then edit
# config.js with your Railway URL (or, if you later add a build framework, wire
# this to VITE_API_URL / NEXT_PUBLIC_API_URL instead).
# ============================================================================
SYNAPSE_API_URL=
